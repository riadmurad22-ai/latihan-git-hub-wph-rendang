{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* 1. Tambahkan baris ini untuk membungkam peringatan baseUrl */
    "ignoreDeprecations": "5.0",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* 2. Pastikan strict false agar error tipe data tidak menggagalkan Vercel */
    "strict": false
  },
  "include": ["src"]
}
